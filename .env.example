# PostgreSQL DSN — same one the render-engine site uses
CONNECTION_STRING=postgresql://user:password@localhost:5432/dbname

# Path to the render-engine site's pyproject.toml containing [tool.render-engine.pg] SQL
SITE_PYPROJECT=/absolute/path/to/site/pyproject.toml

# GitHub API — used to trigger a rebuild via workflow_dispatch
GITHUB_TOKEN=github_pat_xxx
GITHUB_REPO=owner/repo
GITHUB_WORKFLOW=publish.yml
GITHUB_REF=main

# Mastodon — MASTODON_ACCESS_TOKEN is injected by `just dev` / `just serve`
# from 1Password (op://Private/mastodon.social/access-token). Don't hard-code it here.
MASTODON_INSTANCE=https://mastodon.social
MASTODON_VISIBILITY=public

# Used to resolve relative image_url values (e.g. "/images/foo.webp") when
# posting to Mastodon. Leave blank if all your image_url values are absolute.
SITE_BASE_URL=https://example.com

# webmention.io — WEBMENTION_IO_TOKEN is injected from 1Password by just recipes.
WEBMENTION_URL_TEMPLATE={base}/{type}/{slug}/

# Bluesky
BLUESKY_HANDLE=you.example.com
