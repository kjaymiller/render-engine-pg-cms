# .env holds NON-SECRET config only. Secrets live in fnox (age-encrypted) and
# are injected by the mise tasks via `fnox exec`. See docs/reference/configuration.md.
#
# Secrets managed in fnox (set with `printf '%s' "<value>" | fnox set <KEY> -p age`):
#   CONNECTION_STRING  GITHUB_TOKEN  MASTODON_ACCESS_TOKEN  WEBMENTION_IO_TOKEN
#   BLUESKY_APP_PASSWORD  AZURE_STORAGE_CONNECTION_STRING  CMS_API_TOKEN

# Path to the render-engine site's pyproject.toml containing [tool.render-engine.pg] SQL
SITE_PYPROJECT=/absolute/path/to/site/pyproject.toml

# GitHub API — used to trigger a rebuild via workflow_dispatch (GITHUB_TOKEN is in fnox)
GITHUB_REPO=owner/repo
GITHUB_WORKFLOW=publish.yml
GITHUB_REF=main

# Mastodon (MASTODON_ACCESS_TOKEN is in fnox)
MASTODON_INSTANCE=https://mastodon.social
MASTODON_VISIBILITY=public

# Used to resolve relative image_url values (e.g. "/images/foo.webp") when
# posting to Mastodon. Leave blank if all your image_url values are absolute.
SITE_BASE_URL=https://example.com

# webmention.io (WEBMENTION_IO_TOKEN is in fnox)
WEBMENTION_URL_TEMPLATE={base}/{type}/{slug}.html

# Bluesky (BLUESKY_APP_PASSWORD is in fnox)
BLUESKY_HANDLE=you.example.com
