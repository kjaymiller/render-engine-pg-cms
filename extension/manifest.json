{
  "manifest_version": 3,
  "name": "pg-cms quick capture",
  "version": "0.1.1",
  "description": "Send the current tab to render-engine pg-cms for a quick microblog, notes, or blog entry.",
  "browser_specific_settings": {
    "gecko": {
      "id": "pg-cms-quick-capture@kjaymiller.dev"
    }
  },
  "permissions": ["activeTab", "storage", "tabs"],
  "action": {
    "default_title": "Capture to pg-cms",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.svg",
      "96": "icon.svg"
    }
  },
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  },
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
